<ui:FluentWindow
    x:Class="DailyTasks.Views.OrganizeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Organize"
    Width="560"
    MaxHeight="820"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="HeaderBar"
            Grid.Row="0"
            Title="Organize as…"
            ShowMaximize="False"
            ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <StackPanel x:Name="TitleRow" Margin="0,0,0,14" Visibility="Collapsed">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Project name" />
                <ui:TextBox x:Name="TitleBox" PlaceholderText="Ship the billing rewrite" />
            </StackPanel>

            <TextBlock
                Margin="0,0,0,10"
                FontSize="13"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Pick a methodology to unlock phase grouping, the right chart and Excel export. The visualization is chosen automatically to fit the process."
                TextWrapping="Wrap" />

            <ScrollViewer MaxHeight="440" VerticalScrollBarVisibility="Auto">
                <!--  Grouped methodology options are generated in code-behind.  -->
                <StackPanel x:Name="MethodologyList" Margin="0,0,10,0" />
            </ScrollViewer>

            <StackPanel x:Name="IterationRow" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock x:Name="IterationLabel" Margin="0,0,0,6" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Number of iterations" />
                <ui:NumberBox x:Name="IterationCountBox" Width="140" HorizontalAlignment="Left" Maximum="20" Minimum="1" SpinButtonPlacementMode="Inline" Value="3" />
            </StackPanel>

            <StackPanel x:Name="SprintLengthRow" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock Margin="0,0,0,6" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Sprint length (days)" />
                <ui:NumberBox x:Name="SprintLengthBox" Width="140" HorizontalAlignment="Left" Maximum="60" Minimum="1" SpinButtonPlacementMode="Inline" Value="14" />
            </StackPanel>

            <StackPanel x:Name="WipRow" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock Margin="0,0,0,6" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="In-progress WIP limit (leave empty for none)" />
                <ui:NumberBox x:Name="WipLimitBox" Width="140" HorizontalAlignment="Left" ClearButtonEnabled="True" Maximum="20" Minimum="1" SpinButtonPlacementMode="Inline" />
            </StackPanel>
        </StackPanel>

        <DockPanel Grid.Row="2" Margin="0,20,0,0">
            <ui:Button
                x:Name="RemoveButton"
                Padding="14,8"
                Appearance="Secondary"
                Click="OnRemove"
                Content="Remove structure"
                DockPanel.Dock="Left"
                Visibility="Collapsed" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ui:Button Margin="0,0,8,0" Padding="14,8" Appearance="Secondary" Click="OnCancel" Content="Cancel" />
                <ui:Button Padding="14,8" Appearance="Primary" Click="OnApply" Content="Apply" Icon="{ui:SymbolIcon Checkmark24}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
