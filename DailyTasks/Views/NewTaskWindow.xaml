<ui:FluentWindow
    x:Class="DailyTasks.Views.NewTaskWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="New task"
    Width="460"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24,8,24,24">
        <ui:TitleBar Title="New task" ShowMaximize="False" ShowMinimize="False" />

        <TextBlock
            Margin="0,12,0,6"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="Title" />
        <ui:TextBox x:Name="TitleBox" PlaceholderText="Call the dentist" />

        <Grid Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Category" />
                <ComboBox x:Name="CategoryBox" HorizontalAlignment="Stretch" DisplayMemberPath="Name" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Priority" />
                <ComboBox x:Name="PriorityBox" Width="110" SelectedIndex="1">
                    <ComboBoxItem Content="High" />
                    <ComboBoxItem Content="Medium" />
                    <ComboBoxItem Content="Low" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock
                    Margin="0,0,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Due date" />
                <DatePicker x:Name="DueBox" Width="140" />
            </StackPanel>
        </Grid>

        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Margin="0,0,8,0"
                Padding="14,8"
                Appearance="Secondary"
                Click="OnCancel"
                Content="Cancel" />
            <ui:Button
                Padding="14,8"
                Appearance="Primary"
                Click="OnCreate"
                Content="Create task"
                Icon="{ui:SymbolIcon Add24}" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
