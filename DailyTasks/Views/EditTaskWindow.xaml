<ui:FluentWindow
    x:Class="DailyTasks.Views.EditTaskWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Edit task"
    Width="480"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24,8,24,24">
        <ui:TitleBar Title="Edit task" ShowMaximize="False" ShowMinimize="False" />

        <TextBlock
            Margin="0,12,0,6"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="Title" />
        <ui:TextBox x:Name="TitleBox" />

        <TextBlock
            Margin="0,14,0,6"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="Why does this matter?  (shown on the card)" />
        <ui:TextBox x:Name="WhyBox" PlaceholderText="so I don't get charged a late fee" />

        <TextBlock
            Margin="0,14,0,6"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="Estimated minutes" />
        <ui:NumberBox
            x:Name="EstimateBox"
            Maximum="960"
            Minimum="0"
            PlaceholderText="30"
            SpinButtonPlacementMode="Inline" />

        <TextBlock
            Margin="0,14,0,6"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="Repeats — a new copy is created when you complete it" />
        <ComboBox
            x:Name="RecurrenceBox"
            HorizontalAlignment="Left"
            Width="200"
            SelectedIndex="0">
            <ComboBoxItem Content="Does not repeat" />
            <ComboBoxItem Content="Daily" />
            <ComboBoxItem Content="Weekly" />
            <ComboBoxItem Content="Monthly" />
        </ComboBox>

        <TextBlock
            Margin="0,14,0,6"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="Where you left off" />
        <ui:TextBox x:Name="ResumeBox" PlaceholderText="was debugging the auth token refresh, check line 84" />

        <StackPanel x:Name="GitRow">
            <TextBlock
                Margin="0,14,0,6"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Git link — completes this task when a commit message contains it" />
            <ui:TextBox
                x:Name="GitBox"
                FontFamily="Cascadia Mono, Consolas"
                PlaceholderText="closes #42  ·  feature/auth-refresh" />
        </StackPanel>

        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Margin="0,0,8,0"
                Padding="14,8"
                Appearance="Secondary"
                Click="OnCancel"
                Content="Cancel" />
            <ui:Button
                Padding="14,8"
                Appearance="Primary"
                Click="OnSave"
                Content="Save" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
