<Window
    x:Class="DailyTasks.Views.QuickCaptureWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Quick capture"
    Width="640"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <Border
        Margin="18"
        Padding="16"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="28"
                Direction="270"
                Opacity="0.45"
                ShadowDepth="6"
                Color="Black" />
        </Border.Effect>

        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:SymbolIcon
                    Grid.Column="0"
                    Margin="2,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="20"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Symbol="Flash24" />

                <ui:TextBox
                    x:Name="CaptureBox"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    BorderThickness="0"
                    FontSize="18"
                    PlaceholderText="Capture a task…  try “call dentist tomorrow 3pm high priority”"
                    Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <TextBlock
                Margin="46,10,0,0"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding Preview}"
                TextTrimming="CharacterEllipsis"
                Visibility="{Binding Preview, Converter={StaticResource EmptyToVisibility}}" />

            <TextBlock
                Margin="46,10,0,0"
                FontSize="11"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                Text="Enter to save · Esc to dismiss" />
        </StackPanel>
    </Border>
</Window>
