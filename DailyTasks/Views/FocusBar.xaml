<UserControl
    x:Class="DailyTasks.Views.FocusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">

    <Border
        Margin="16,4,16,8"
        Padding="14,10"
        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:SymbolIcon
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="18"
                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                Symbol="Timer24" />

            <StackPanel
                Grid.Column="1"
                Margin="10,0,0,0"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="11"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="FOCUSING ON" />
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding TaskTitle}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <TextBlock
                Grid.Column="2"
                Margin="16,0"
                VerticalAlignment="Center"
                FontFamily="Segoe UI Variable Display"
                FontSize="26"
                FontWeight="Bold"
                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                Text="{Binding RemainingText}" />

            <!--  Running: interrupt + stop. Paused: reason chips + resume.  -->
            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ui:Button
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Appearance="Secondary"
                        Command="{Binding InterruptCommand}"
                        Content="I got interrupted"
                        Icon="{ui:SymbolIcon Pause24}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="What pulled you away?" />

                    <ItemsControl ItemsSource="{Binding Reasons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Button
                                    Margin="0,0,6,0"
                                    Padding="10,5"
                                    Appearance="Secondary"
                                    Command="{Binding DataContext.ResumeWithReasonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding}"
                                    FontSize="12" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ui:Button
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Appearance="Primary"
                        Command="{Binding ResumeCommand}"
                        Content="Resume"
                        Icon="{ui:SymbolIcon Play24}" />
                </StackPanel>

                <ui:Button
                    Padding="12,6"
                    Appearance="Transparent"
                    Command="{Binding StopCommand}"
                    Content="Stop"
                    Icon="{ui:SymbolIcon Dismiss24}"
                    ToolTip="End the session" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
