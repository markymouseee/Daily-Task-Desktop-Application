<ui:FluentWindow
    x:Class="DailyTasks.Views.TaskDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:DailyTasks.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Task"
    Width="980"
    Height="740"
    MinWidth="760"
    MinHeight="540"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid Margin="24,8,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="{Binding Title}" />

            <!--  Header  -->
            <Border
                Grid.Row="1"
                Margin="0,8,0,16"
                Padding="18,16"
                Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontFamily="Segoe UI Variable Display"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />
                            <Border
                                Margin="12,2,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding MethodologyBadge}" />
                            </Border>
                            <Border
                                Margin="8,2,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                    Text="{Binding CategoryName}" />
                            </Border>
                        </StackPanel>

                        <TextBlock
                            Margin="0,10,0,0"
                            FontSize="13"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding OverallText}" />

                        <Border
                            x:Name="OverallTrack"
                            Height="10"
                            Margin="0,8,0,0"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            ClipToBounds="True"
                            CornerRadius="5">
                            <Border
                                HorizontalAlignment="Left"
                                Background="{Binding OverallFraction, Converter={StaticResource ProgressToBrush}}"
                                CornerRadius="5">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource FractionOfWidth}">
                                        <Binding Path="OverallFraction" />
                                        <Binding ElementName="OverallTrack" Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="Segoe UI Variable Display"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding OverallPercent, StringFormat={}{0}%}" />
                        <Border
                            Margin="0,4,0,0"
                            Padding="8,2"
                            HorizontalAlignment="Right"
                            Background="#33EF4444"
                            CornerRadius="7"
                            Visibility="{Binding BlockedCount, Converter={StaticResource PositiveToVisibility}}">
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#EF4444"
                                Text="{Binding BlockedCount, StringFormat={}{0} blocked}" />
                        </Border>
                        <StackPanel
                            Margin="0,12,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <ui:Button
                                Appearance="Secondary"
                                Command="{Binding ManageTeamCommand}"
                                Content="Team"
                                Icon="{ui:SymbolIcon People24}"
                                ToolTip="Manage this project's team" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Appearance="Secondary"
                                Command="{Binding OpenCommitsCommand}"
                                Content="Commits"
                                Icon="{ui:SymbolIcon BranchFork24}"
                                ToolTip="This project's git repository and recent commits"
                                Visibility="{Binding ShowDeveloperTools, Converter={StaticResource BoolToVisibility}}" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Appearance="Secondary"
                                Command="{Binding ExportGanttCommand}"
                                Content="Export Gantt"
                                Icon="{ui:SymbolIcon DataBarHorizontal24}"
                                IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBool}}"
                                ToolTip="Export the Gantt chart to a styled Excel workbook"
                                Visibility="{Binding HasGantt, Converter={StaticResource BoolToVisibility}}" />
                            <ui:Button
                                Margin="8,0,0,0"
                                Appearance="Secondary"
                                Command="{Binding ExportCommand}"
                                Content="Export"
                                Icon="{ui:SymbolIcon DocumentTable24}"
                                IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBool}}"
                                ToolTip="Export the full SDLC to Excel" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  List / chart toggle (chart label varies by methodology)  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,0,0,14"
                Orientation="Horizontal"
                Visibility="{Binding HasChartToggle, Converter={StaticResource BoolToVisibility}}">
                <RadioButton
                    MinWidth="88"
                    Content="List"
                    GroupName="DetailView"
                    IsChecked="{Binding IsGanttView, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                    Style="{StaticResource ViewToggle}" />
                <RadioButton
                    MinWidth="88"
                    Content="{Binding ChartToggleLabel}"
                    GroupName="DetailView"
                    IsChecked="{Binding IsGanttView, Mode=TwoWay}"
                    Style="{StaticResource ViewToggle}" />
            </StackPanel>

            <!--  Phased list  -->
            <ScrollViewer
                Grid.Row="3"
                Margin="0,0,-12,0"
                Padding="0,0,12,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding ShowPhasedList, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Phases}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PhaseRowViewModel}">
                            <Border
                                x:Name="PhaseCard"
                                Margin="0,0,0,14"
                                Padding="16,14"
                                Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                x:Name="LockIcon"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Symbol="LockClosed24"
                                                Visibility="Collapsed" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding DisplayName}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding ProgressText}" />
                                        </StackPanel>
                                    </Grid>

                                    <ContentControl
                                        Margin="0,10,0,0"
                                        HorizontalContentAlignment="Stretch"
                                        Content="{Binding}"
                                        ContentTemplate="{StaticResource PhaseProgressBar}" />

                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Tasks}" />

                                    <Border
                                        Margin="0,4,0,0"
                                        Padding="6"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Icon="{ui:SymbolIcon Add24}"
                                                PlaceholderText="Add a task to this phase…"
                                                Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}">
                                                <ui:TextBox.InputBindings>
                                                    <KeyBinding
                                                        Key="Enter"
                                                        Command="{Binding DataContext.AddToPhaseCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                                                        CommandParameter="{Binding}" />
                                                </ui:TextBox.InputBindings>
                                            </ui:TextBox>
                                            <ui:Button
                                                Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Padding="12,8"
                                                Appearance="Secondary"
                                                Command="{Binding DataContext.AddToPhaseCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Add24}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                    <Setter TargetName="PhaseCard" Property="Opacity" Value="0.45" />
                                    <Setter TargetName="PhaseCard" Property="IsEnabled" Value="False" />
                                    <Setter TargetName="LockIcon" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!--  Sequential Gantt (Waterfall)  -->
            <views:GanttChart
                Grid.Row="3"
                DataContext="{Binding Gantt}"
                Visibility="{Binding DataContext.ShowSequentialGantt, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}, Converter={StaticResource BoolToVisibility}}" />

            <!--  V-Shaped Gantt (V-Model)  -->
            <views:VShapedGanttChart
                Grid.Row="3"
                DataContext="{Binding VGantt}"
                Visibility="{Binding DataContext.ShowVGantt, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}, Converter={StaticResource BoolToVisibility}}" />

            <!--  Cyclical Gantt (Spiral / Iterative &amp; Incremental / RAD)  -->
            <views:CyclicalGanttChart
                Grid.Row="3"
                DataContext="{Binding CycleGantt}"
                Visibility="{Binding DataContext.ShowCyclicalGantt, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}, Converter={StaticResource BoolToVisibility}}" />

            <!--  Agile Gantt (Agile / Scrum / XP) — grouped by sprint  -->
            <views:AgileGanttChart
                Grid.Row="3"
                DataContext="{Binding AgileGantt}"
                Visibility="{Binding DataContext.ShowAgileGantt, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}, Converter={StaticResource BoolToVisibility}}" />

            <!--  DevOps pipeline  -->
            <views:PipelineChart
                Grid.Row="3"
                VerticalAlignment="Top"
                DataContext="{Binding Pipeline}"
                Visibility="{Binding DataContext.ShowPipeline, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}, Converter={StaticResource BoolToVisibility}}" />

            <!--  Big Bang flat list  -->
            <ScrollViewer
                Grid.Row="3"
                Margin="0,0,-12,0"
                Padding="0,0,12,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding UsesFlatList, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding FlatItems}" />
            </ScrollViewer>

            <!--  Kanban / Lean board  -->
            <Grid Grid.Row="3" Visibility="{Binding UsesBoard, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,6,0" Padding="10" Style="{StaticResource Card}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="To Do" />
                            <ui:Button
                                Grid.Column="1"
                                Padding="6"
                                Appearance="Transparent"
                                Command="{Binding AddKanbanCommand}"
                                Icon="{ui:SymbolIcon Add24}"
                                ToolTip="Add task" />
                        </Grid>
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding TodoColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:WorkStatus.Todo}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border
                    x:Name="InProgressColumnCard"
                    Grid.Column="1"
                    Margin="6,0,6,0"
                    Padding="10">
                    <Border.Style>
                        <Style BasedOn="{StaticResource Card}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WipExceeded}" Value="True">
                                    <Setter Property="BorderBrush" Value="#EF4444" />
                                    <Setter Property="BorderThickness" Value="1.5" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="In Progress" />
                            <Border
                                x:Name="WipBadge"
                                Grid.Column="1"
                                Padding="7,1"
                                CornerRadius="9"
                                ToolTip="Work-in-progress limit"
                                Visibility="{Binding HasWipLimit, Converter={StaticResource BoolToVisibility}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WipExceeded}" Value="True">
                                                <Setter Property="Background" Value="#33EF4444" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock
                                    x:Name="WipBadgeText"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Text="{Binding WipBadge}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding WipExceeded}" Value="True">
                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding InProgressColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:WorkStatus.InProgress}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Margin="6,0,6,0" Padding="10" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Review" />
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding ReviewColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:WorkStatus.Review}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="3" Margin="6,0,0,0" Padding="10" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Done" />
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding DoneColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:WorkStatus.Done}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!--  Export veil  -->
        <Border Background="#99000000" Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    Foreground="White"
                    Text="Building your Excel workbook…" />
            </StackPanel>
        </Border>

        <!--  Complete prompt  -->
        <Border Background="#B2000000" Visibility="{Binding ShowCompletePrompt, Converter={StaticResource BoolToVisibility}}">
            <Border
                MaxWidth="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI Variable Display"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Every subtask is done." />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Mark the whole task complete?"
                        TextWrapping="Wrap" />
                    <StackPanel Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Appearance="Secondary"
                            Command="{Binding DismissCompletePromptCommand}"
                            Content="Not yet" />
                        <ui:Button
                            Padding="14,8"
                            Appearance="Primary"
                            Command="{Binding MarkProjectCompleteCommand}"
                            Content="Mark complete"
                            Icon="{ui:SymbolIcon CheckmarkCircle24}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</ui:FluentWindow>
