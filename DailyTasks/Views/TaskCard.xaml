<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels">

    <views:HexToBrushConverter x:Key="HexToBrush" />
    <views:PriorityToBrushConverter x:Key="PriorityToBrush" />
    <views:DueDateToTextConverter x:Key="DueDateToText" />
    <views:DueDateIsOverdueConverter x:Key="DueDateIsOverdue" />
    <views:NullToVisibilityConverter x:Key="NullToVisibility" />
    <views:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    <views:EmptyToVisibilityConverter x:Key="EmptyToVisibility" />

    <!--  Kept in sync with Palette.Priority in Converters.cs  -->
    <SolidColorBrush x:Key="PriorityHighBrush" Color="#EF4444" />

    <!--  A task card. Applied implicitly wherever a TaskItemViewModel is rendered.  -->
    <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
        <Border
            x:Name="CardRoot"
            Margin="0,0,0,10"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Accent strip, shown only on Big 3 cards to set them apart  -->
                <Border
                    x:Name="AccentStrip"
                    Grid.Column="0"
                    Background="Transparent"
                    CornerRadius="12,0,0,12" />

                <CheckBox
                    Grid.Column="1"
                    Margin="14,0,4,0"
                    VerticalAlignment="Center"
                    IsChecked="{Binding IsCompleted}" />

                <StackPanel
                    Grid.Column="2"
                    Margin="4,14,12,14"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{Binding Title}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />

                    <!--  Why this matters  -->
                    <TextBlock
                        Margin="0,3,0,0"
                        FontSize="12"
                        FontStyle="Italic"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding WhyReason}"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{Binding WhyReason, Converter={StaticResource EmptyToVisibility}}" />

                    <!--  Where you left off — shown prominently when returning to a task  -->
                    <StackPanel
                        Margin="0,6,0,0"
                        Orientation="Horizontal"
                        Visibility="{Binding ContextResumeNote, Converter={StaticResource EmptyToVisibility}}">
                        <ui:SymbolIcon
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Symbol="Comment24" />
                        <TextBlock
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                            Text="{Binding ContextResumeNote}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                        <!--  Category pill  -->
                        <Border
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                            CornerRadius="8">
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                Text="{Binding CategoryName}" />
                        </Border>

                        <!--  Git link (developer feature)  -->
                        <StackPanel
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="{Binding GitLink, Converter={StaticResource EmptyToVisibility}}">
                            <ui:SymbolIcon
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Symbol="BranchFork24" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="Cascadia Mono, Consolas"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding GitLink}" />
                        </StackPanel>

                        <!--  Due date  -->
                        <StackPanel
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="{Binding DueDate, Converter={StaticResource NullToVisibility}}">
                            <ui:SymbolIcon
                                x:Name="DueIcon"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Symbol="CalendarLtr24" />
                            <TextBlock
                                x:Name="DueText"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding DueDate, Converter={StaticResource DueDateToText}}" />
                        </StackPanel>

                        <!--  Recurrence  -->
                        <StackPanel
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="{Binding IsRecurring, Converter={StaticResource BoolToVisibility}}">
                            <ui:SymbolIcon
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Symbol="ArrowRepeatAll24" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding RecurrenceLabel}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="3"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <!--  Priority pill  -->
                    <Border
                        Padding="9,3"
                        VerticalAlignment="Center"
                        Background="{Binding Priority, Converter={StaticResource PriorityToBrush}, ConverterParameter=Fill}"
                        CornerRadius="8">
                        <TextBlock
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{Binding Priority, Converter={StaticResource PriorityToBrush}}"
                            Text="{Binding Priority}" />
                    </Border>

                    <!--  Actions, revealed on hover  -->
                    <StackPanel
                        x:Name="Actions"
                        Margin="6,0,0,0"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                        <ui:Button
                            x:Name="FocusButton"
                            Padding="8"
                            AutomationProperties.Name="Start focus"
                            Appearance="Transparent"
                            Command="{Binding DataContext.StartFocusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Icon="{ui:SymbolIcon Play24}"
                            ToolTip="Start a focus session" />
                        <ui:Button
                            Padding="8"
                            AutomationProperties.Name="Edit task"
                            Appearance="Transparent"
                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Icon="{ui:SymbolIcon Edit24}"
                            ToolTip="Edit task" />
                        <ui:Button
                            Padding="8"
                            AutomationProperties.Name="Delete task"
                            Appearance="Transparent"
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Icon="{ui:SymbolIcon Delete24}"
                            ToolTip="Delete task" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <DataTemplate.Triggers>
            <!--  Big 3 cards carry an accent left strip; regular cards don't  -->
            <DataTrigger Binding="{Binding Model.BigThreeDate, Converter={StaticResource IsToday}}" Value="True">
                <Setter TargetName="AccentStrip" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            </DataTrigger>

            <!--  Action buttons appear on hover, keeping the resting card clean  -->
            <Trigger SourceName="CardRoot" Property="IsMouseOver" Value="True">
                <Setter TargetName="Actions" Property="Visibility" Value="Visible" />
            </Trigger>

            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                <Setter TargetName="TitleText" Property="TextDecorations" Value="Strikethrough" />
                <Setter TargetName="TitleText" Property="Opacity" Value="0.55" />
                <Setter TargetName="FocusButton" Property="Visibility" Value="Collapsed" />
            </DataTrigger>

            <DataTrigger Binding="{Binding DueDate, Converter={StaticResource DueDateIsOverdue}}" Value="True">
                <Setter TargetName="DueText" Property="Foreground" Value="{StaticResource PriorityHighBrush}" />
                <Setter TargetName="DueIcon" Property="Foreground" Value="{StaticResource PriorityHighBrush}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
</ResourceDictionary>
