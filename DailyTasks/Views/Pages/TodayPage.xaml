<Page
    x:Class="DailyTasks.Views.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Today">

    <Page.Resources>
        <!--  Grouping and sorting are a view concern, so they live here rather than in the view model.  -->
        <CollectionViewSource x:Key="GroupedTasks" Source="{Binding Items}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription Direction="Descending" PropertyName="Priority" />
                <scm:SortDescription Direction="Ascending" PropertyName="DueSortKey" />
            </CollectionViewSource.SortDescriptions>
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Priority" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Page.Resources>

    <Grid>
        <Grid Margin="28,16,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock
                    FontFamily="Segoe UI Variable Display"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="Today" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:dddd, d MMMM}'}" />
            </StackPanel>

            <!--  Quick add  -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <Border
                    Padding="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="16"
                            Direction="270"
                            Opacity="0.18"
                            ShadowDepth="2"
                            Color="Black" />
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:TextBox
                            x:Name="QuickAddBox"
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Icon="{ui:SymbolIcon Add24}"
                            PlaceholderText="Add a task and press Enter…  try “call dentist tomorrow 3pm high priority”"
                            Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding AddTaskCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <ComboBox
                            Grid.Column="1"
                            Width="118"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding NewTaskCategory}"
                            ToolTip="Category" />

                        <ComboBox
                            Grid.Column="2"
                            Width="108"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding Priorities}"
                            SelectedItem="{Binding NewTaskPriority}"
                            ToolTip="Priority" />

                        <DatePicker
                            Grid.Column="3"
                            Width="140"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            SelectedDate="{Binding NewTaskDueDate}"
                            ToolTip="Due date" />

                        <ui:Button
                            Grid.Column="4"
                            Padding="14,8"
                            VerticalAlignment="Center"
                            Appearance="Primary"
                            Command="{Binding AddTaskCommand}"
                            Content="Add"
                            Icon="{ui:SymbolIcon Add24}" />
                    </Grid>
                </Border>

                <!--  Live echo of what the parser understood  -->
                <StackPanel
                    Margin="12,8,0,0"
                    Orientation="Horizontal"
                    Visibility="{Binding ParsePreview, Converter={StaticResource EmptyToVisibility}}">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Symbol="Sparkle24" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding ParsePreview}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>

            <!--  Task cards  -->
            <Grid Grid.Row="2">
                <ScrollViewer
                    Margin="0,0,-12,0"
                    Padding="0,0,12,0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  Today's Big 3, pinned above everything else  -->
                        <StackPanel Visibility="{Binding HasBigThree, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Margin="2,0,0,10" Orientation="Horizontal">
                                <ui:SymbolIcon
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Symbol="Pin24" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    Text="TODAY'S BIG 3" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding BigThree}" />

                            <Border
                                Height="1"
                                Margin="0,6,0,4"
                                Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                        </StackPanel>

                        <!--  Everything else, grouped by priority  -->
                        <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedTasks}}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="2,10,0,10"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding Name, StringFormat='{}{0} priority'}" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!--  Empty state  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="40"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Symbol="Broom24" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding EmptyMessage}" />
                </StackPanel>
            </Grid>
        </Grid>

        <!--  Morning ritual: pick the top 3 before the full list is usable  -->
        <Border Background="#B2000000" Visibility="{Binding ShowBigThreePrompt, Converter={StaticResource BoolToVisibility}}">
            <Border
                MaxWidth="520"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="30"
                        Direction="270"
                        Opacity="0.5"
                        ShadowDepth="6"
                        Color="Black" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI Variable Display"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="What are your Big 3 today?" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Pick the three that must get done. They stay pinned at the top."
                        TextWrapping="Wrap" />

                    <ScrollViewer MaxHeight="260" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BigThreeCandidates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:BigThreeCandidate}">
                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="10,8"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding Title}" />
                                                <Border
                                                    Margin="8,0,0,0"
                                                    Padding="6,1"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                                                    CornerRadius="7">
                                                    <TextBlock
                                                        FontSize="10"
                                                        FontWeight="SemiBold"
                                                        Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                                        Text="{Binding CategoryName}" />
                                                </Border>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding BigThreePromptHint}" />

                    <StackPanel
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Appearance="Secondary"
                            Command="{Binding SkipBigThreeCommand}"
                            Content="Skip today" />
                        <ui:Button
                            Padding="14,8"
                            Appearance="Primary"
                            Command="{Binding ConfirmBigThreeCommand}"
                            Content="Pin them"
                            Icon="{ui:SymbolIcon Pin24}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
