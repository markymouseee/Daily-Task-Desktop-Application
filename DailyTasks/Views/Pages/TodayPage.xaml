<Page
    x:Class="DailyTasks.Views.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Today">

    <Page.Resources>
        <!--  Grouping and sorting are a view concern, so they live here rather than in the view model.  -->
        <CollectionViewSource x:Key="GroupedTasks" Source="{Binding Items}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription Direction="Descending" PropertyName="Priority" />
                <scm:SortDescription Direction="Ascending" PropertyName="DueSortKey" />
            </CollectionViewSource.SortDescriptions>
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Priority" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Page.Resources>

    <Grid>
        <Grid Margin="28,16,28,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="GreetingText" Style="{StaticResource PageHeading}" Text="Hello" />
                    <TextBlock x:Name="SubheadingText" Style="{StaticResource PageSubheading}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:Button
                        Padding="16,10"
                        Appearance="Primary"
                        Click="OnNewTask"
                        Content="New Task"
                        FontSize="14"
                        Icon="{ui:SymbolIcon Add24}" />
                    <ui:Button
                        x:Name="KebabButton"
                        Margin="8,0,0,0"
                        Padding="11,10"
                        Appearance="Secondary"
                        Click="OnKebab"
                        Icon="{ui:SymbolIcon MoreHorizontal24}"
                        ToolTip="More">
                        <ui:Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem
                                    Command="{Binding PlacementTarget.DataContext.NewProjectFromMenuCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    Header="New project…" />
                                <MenuItem
                                    Command="{Binding PlacementTarget.DataContext.ManageTeamCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    Header="Manage team…" />
                            </ContextMenu>
                        </ui:Button.ContextMenu>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <!--  Quick add  -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <!--  Clean, prominent quick-add. Type naturally — "call dentist tomorrow 3pm
                      high priority" — the parser fills in the date, priority and category.  -->
                <ui:TextBox
                    x:Name="QuickAddBox"
                    Padding="8,10"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Icon="{ui:SymbolIcon Search24}"
                    PlaceholderText="Quick add a task…"
                    Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}">
                    <ui:TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding AddTaskCommand}" />
                    </ui:TextBox.InputBindings>
                </ui:TextBox>

                <!--  Stale-task nudge  -->
                <Border
                    Margin="0,10,0,0"
                    Padding="12,10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="#66F59E0B"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding ShowStaleNudge, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="#F59E0B"
                            Symbol="QuestionCircle24" />

                        <StackPanel
                            Grid.Column="1"
                            Margin="10,0,10,0"
                            VerticalAlignment="Center">
                            <TextBlock
                                FontSize="13"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding StaleText}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="{Binding StaleMoreText}"
                                Visibility="{Binding StaleMoreText, Converter={StaticResource EmptyToVisibility}}" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <ui:Button
                                Margin="0,0,6,0"
                                Padding="10,5"
                                Appearance="Primary"
                                Command="{Binding StaleDoNowCommand}"
                                Content="Do it now"
                                FontSize="12"
                                Icon="{ui:SymbolIcon Play24}" />
                            <ui:Button
                                Margin="0,0,6,0"
                                Padding="10,5"
                                Appearance="Secondary"
                                Command="{Binding StaleRescheduleCommand}"
                                Content="Reschedule"
                                FontSize="12"
                                Icon="{ui:SymbolIcon ArrowClockwise24}" />
                            <ui:Button
                                Margin="0,0,6,0"
                                Padding="10,5"
                                Appearance="Secondary"
                                Command="{Binding StaleDeleteCommand}"
                                Content="Delete"
                                FontSize="12"
                                Icon="{ui:SymbolIcon Delete24}" />
                            <ui:Button
                                Padding="10,5"
                                Appearance="Transparent"
                                Command="{Binding StaleSkipCommand}"
                                Content="Not now"
                                FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Live echo of what the parser understood  -->
                <StackPanel
                    Margin="12,8,0,0"
                    Orientation="Horizontal"
                    Visibility="{Binding ParsePreview, Converter={StaticResource EmptyToVisibility}}">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Symbol="Sparkle24" />
                    <TextBlock
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding ParsePreview}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!--  Task/time mismatch warning  -->
                <Border
                    Margin="0,10,0,0"
                    Padding="12,10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="#66EF4444"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding ShowWorkloadWarning, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="#EF4444"
                            Symbol="Warning24" />

                        <TextBlock
                            Grid.Column="1"
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding WorkloadText}"
                            TextWrapping="Wrap" />

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Free hours today" />
                            <ui:NumberBox
                                Width="110"
                                LargeChange="1"
                                Maximum="24"
                                Minimum="0"
                                SmallChange="0.5"
                                SpinButtonPlacementMode="Inline"
                                Value="{Binding FreeHoursToday, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!--  Task cards  -->
            <Grid Grid.Row="2">
                <ScrollViewer
                    x:Name="TasksScroll"
                    Margin="0,0,-12,0"
                    Padding="0,0,12,0"
                    HorizontalScrollBarVisibility="Disabled"
                    ScrollChanged="OnTasksScrollChanged"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  Today's Big 3, pinned above everything else  -->
                        <StackPanel Visibility="{Binding HasBigThree, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="TODAY'S BIG 3" />

                            <ItemsControl ItemsSource="{Binding BigThree}" />

                            <Border
                                Height="1"
                                Margin="0,6,0,14"
                                Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                        </StackPanel>

                        <!--  Active projects, shown as distinct cards  -->
                        <StackPanel Visibility="{Binding HasProjects, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource SectionLabel}" Text="PROJECTS" />

                            <ItemsControl ItemsSource="{Binding TodayProjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ProjectViewModel}">
                                        <Button
                                            Margin="0,0,0,10"
                                            Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource CardButton}"
                                            ToolTip="Open project">
                                            <Border Style="{StaticResource Card}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!--  Accent stripe marks a project apart from a task  -->
                                                    <Border
                                                        Grid.Column="0"
                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="12,0,0,12" />

                                                    <StackPanel Grid.Column="1" Margin="14,12,12,12">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                            Text="{Binding Title}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <Border
                                                            Margin="10,1,0,0"
                                                            Padding="7,1"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                            CornerRadius="7">
                                                            <TextBlock
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="White"
                                                                Text="{Binding MethodologyBadge}" />
                                                        </Border>
                                                        <Border
                                                            Margin="6,1,0,0"
                                                            Padding="7,1"
                                                            VerticalAlignment="Center"
                                                            Background="#33EF4444"
                                                            CornerRadius="7"
                                                            Visibility="{Binding BlockedCount, Converter={StaticResource PositiveToVisibility}}">
                                                            <TextBlock
                                                                FontSize="10"
                                                                FontWeight="SemiBold"
                                                                Foreground="#EF4444"
                                                                Text="{Binding BlockedText}" />
                                                        </Border>
                                                    </StackPanel>

                                                    <!--  Overall progress  -->
                                                    <Border
                                                        x:Name="TodayProjTrack"
                                                        Height="6"
                                                        Margin="0,8,0,0"
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        ClipToBounds="True"
                                                        CornerRadius="3">
                                                        <Border
                                                            HorizontalAlignment="Left"
                                                            Background="{Binding ProgressFraction, Converter={StaticResource ProgressToBrush}}"
                                                            CornerRadius="3">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{StaticResource FractionOfWidth}">
                                                                    <Binding Path="ProgressFraction" />
                                                                    <Binding ElementName="TodayProjTrack" Path="ActualWidth" />
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                    </Border>

                                                    <TextBlock
                                                        Margin="0,5,0,0"
                                                        FontSize="11"
                                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                        Text="{Binding ProgressText}" />

                                                    <!--  Only the next actionable subtask, to avoid clutter  -->
                                                    <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                                        <ui:SymbolIcon
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                            Symbol="ArrowRight24" />
                                                        <TextBlock
                                                            Margin="5,0,0,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                            Text="{Binding CurrentActionableTitle}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </StackPanel>

                                                    <!--  Chevron affordance — the whole card is clickable  -->
                                                    <ui:SymbolIcon
                                                        Grid.Column="2"
                                                        Margin="0,0,14,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="18"
                                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                        Symbol="ChevronRight24" />
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border
                                Height="1"
                                Margin="0,2,0,10"
                                Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                        </StackPanel>

                        <!--  Everything else, grouped by priority  -->
                        <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedTasks}}">
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Margin="2,10,0,10"
                                                Style="{StaticResource SectionLabel}"
                                                Text="{Binding Name, StringFormat='{}{0} Priority'}" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!--  Empty state  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        FontSize="40"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Symbol="Broom24" />
                    <TextBlock
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding EmptyMessage}" />
                </StackPanel>

                <!--  Scroll-down affordance, shown only when there's more below the fold  -->
                <ui:Button
                    x:Name="ScrollDownButton"
                    Margin="0,0,0,10"
                    Padding="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Appearance="Secondary"
                    Click="OnScrollDown"
                    Icon="{ui:SymbolIcon ChevronDown24}"
                    ToolTip="Scroll down"
                    Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!--  Morning ritual: pick the top 3 before the full list is usable  -->
        <Border Background="#B2000000" Visibility="{Binding ShowBigThreePrompt, Converter={StaticResource BoolToVisibility}}">
            <Border
                MaxWidth="520"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="30"
                        Direction="270"
                        Opacity="0.5"
                        ShadowDepth="6"
                        Color="Black" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI Variable Display"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="What are your Big 3 today?" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Pick the three that must get done. They stay pinned at the top."
                        TextWrapping="Wrap" />

                    <ScrollViewer MaxHeight="260" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BigThreeCandidates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:BigThreeCandidate}">
                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="10,8"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="8">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    Text="{Binding Title}" />
                                                <Border
                                                    Margin="8,0,0,0"
                                                    Padding="6,1"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                                                    CornerRadius="7">
                                                    <TextBlock
                                                        FontSize="10"
                                                        FontWeight="SemiBold"
                                                        Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                                        Text="{Binding CategoryName}" />
                                                </Border>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock
                        Margin="0,10,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding BigThreePromptHint}" />

                    <StackPanel
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Appearance="Secondary"
                            Command="{Binding SkipBigThreeCommand}"
                            Content="Skip today" />
                        <ui:Button
                            Padding="14,8"
                            Appearance="Primary"
                            Command="{Binding ConfirmBigThreeCommand}"
                            Content="Pin them"
                            Icon="{ui:SymbolIcon Pin24}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
