<Page
    x:Class="DailyTasks.Views.Pages.InsightsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Insights">

    <Page.Resources>
        <Style x:Key="InsightCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
    </Page.Resources>

    <Grid Margin="28,16,28,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,18"
            FontFamily="Segoe UI Variable Display"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
            Text="Insights" />

        <ScrollViewer
            Grid.Row="1"
            Margin="0,0,-12,0"
            Padding="0,0,12,0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  Interruptions this week  -->
                <Border Style="{StaticResource InsightCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Symbol="Pause24" />
                            <TextBlock
                                Margin="8,0,0,0"
                                Style="{StaticResource CardTitle}"
                                Text="Interruptions this week" />
                        </StackPanel>

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding InterruptionHeadline}"
                            TextWrapping="Wrap" />

                        <ItemsControl
                            Margin="0,14,0,0"
                            ItemsSource="{Binding InterruptionRows}"
                            Visibility="{Binding HasInterruptions, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:InterruptionRow}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Text="{Binding Label}" />
                                        <Border
                                            Grid.Column="1"
                                            Width="{Binding BarWidth}"
                                            Height="14"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Detail}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--  Completion heatmap  -->
                <Border Style="{StaticResource InsightCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Symbol="CheckmarkCircle24" />
                            <TextBlock
                                Margin="8,0,0,0"
                                Style="{StaticResource CardTitle}"
                                Text="Completions — last 12 weeks" />
                        </StackPanel>

                        <ItemsControl
                            Margin="0,14,0,0"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding HeatCells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="12" Rows="7" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:HeatCell}">
                                    <Border
                                        Width="16"
                                        Height="16"
                                        Margin="2"
                                        CornerRadius="3"
                                        Opacity="{Binding Opacity}"
                                        ToolTip="{Binding Tooltip}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAny}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFuture}" Value="True">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="ToolTip" Value="{x:Null}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="2,10,0,0" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="less" />
                            <Border
                                Width="12"
                                Height="12"
                                Margin="6,0,2,0"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="3" />
                            <Border
                                Width="12"
                                Height="12"
                                Margin="2,0"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="3"
                                Opacity="0.45" />
                            <Border
                                Width="12"
                                Height="12"
                                Margin="2,0,6,0"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="3" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="more" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Category balance  -->
                <Border Style="{StaticResource InsightCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                Symbol="DataPie24" />
                            <TextBlock
                                Margin="8,0,0,0"
                                Style="{StaticResource CardTitle}"
                                Text="Category balance this week" />
                        </StackPanel>

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Nothing completed yet this week — the wheel fills in as you finish tasks.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCategoryData}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel
                            Margin="0,14,0,0"
                            Orientation="Horizontal"
                            Visibility="{Binding HasCategoryData, Converter={StaticResource BoolToVisibility}}">
                            <views:DonutChart
                                Width="150"
                                Height="150"
                                Slices="{Binding CategorySlices}" />

                            <ItemsControl
                                Margin="26,0,0,0"
                                VerticalAlignment="Center"
                                ItemsSource="{Binding CategorySlices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CategorySlice}">
                                        <StackPanel Margin="0,4" Orientation="Horizontal">
                                            <Border
                                                Width="12"
                                                Height="12"
                                                VerticalAlignment="Center"
                                                Background="{Binding ColorHex, Converter={StaticResource HexToBrush}}"
                                                CornerRadius="6" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding Label}" />
                                            <TextBlock
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding Count, StringFormat='{}{0} done'}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
