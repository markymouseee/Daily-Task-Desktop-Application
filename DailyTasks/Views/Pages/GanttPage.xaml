<Page
    x:Class="DailyTasks.Views.Pages.GanttPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    Title="Gantt">

    <Grid Margin="28,16,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource PageHeading}" Text="Gantt" />
                <TextBlock Style="{StaticResource PageSubheading}" Text="Timelines for your methodology-organized tasks." />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <ComboBox
                    MinWidth="220"
                    VerticalAlignment="Center"
                    DisplayMemberPath="Title"
                    ItemsSource="{Binding Projects}"
                    SelectedItem="{Binding SelectedProject}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibility}}" />
                <ui:Button
                    Margin="10,0,0,0"
                    Padding="14,9"
                    Appearance="Primary"
                    Command="{Binding NewProjectCommand}"
                    Content="New project"
                    Icon="{ui:SymbolIcon Add24}" />
            </StackPanel>
        </Grid>

        <views:GanttChart
            Grid.Row="1"
            DataContext="{Binding Gantt}"
            Visibility="{Binding DataContext.ShowSequential, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisibility}}" />

        <views:VShapedGanttChart
            Grid.Row="1"
            DataContext="{Binding VGantt}"
            Visibility="{Binding DataContext.ShowV, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisibility}}" />

        <views:CyclicalGanttChart
            Grid.Row="1"
            DataContext="{Binding CycleGantt}"
            Visibility="{Binding DataContext.ShowCyclical, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisibility}}" />

        <views:AgileGanttChart
            Grid.Row="1"
            DataContext="{Binding AgileGantt}"
            Visibility="{Binding DataContext.ShowAgileGantt, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisibility}}" />

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            <ui:SymbolIcon
                HorizontalAlignment="Center"
                FontSize="40"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                Symbol="DataBarHorizontal24" />
            <TextBlock
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="No organized tasks yet. Add subtasks to a task, then use Organize as… to give it a methodology." />
        </StackPanel>
    </Grid>
</Page>
