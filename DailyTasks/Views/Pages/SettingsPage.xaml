<Page
    x:Class="DailyTasks.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings">

    <StackPanel Margin="28,16,28,0">
        <TextBlock Style="{StaticResource PageHeading}" Text="Settings" />
        <TextBlock
            Margin="0,3,0,18"
            Style="{StaticResource PageSubheading}"
            Text="Preferences, appearance, and developer options." />

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Person24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Your name" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Used for the greeting and your sidebar avatar." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:TextBox
                Width="220"
                PlaceholderText="Mark"
                Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="People24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Team" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Add the people you assign project subtasks to." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:Button
                Command="{Binding ManageTeamCommand}"
                Content="Manage team…"
                Icon="{ui:SymbolIcon PeopleTeam24}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="DarkTheme24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Dark theme" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Switch between the light and dark appearance." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Timer24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Focus session length" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Minutes per Pomodoro." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:NumberBox
                Width="130"
                Maximum="180"
                Minimum="1"
                SpinButtonPlacementMode="Inline"
                Value="{Binding PomodoroMinutes}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="ClockAlarm24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Daily recap time" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="When the end-of-day summary appears (24h clock)." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:TextBox
                Width="130"
                PlaceholderText="18:00"
                Text="{Binding RecapTimeText, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Hourglass24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Free hours per day" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Default used to warn when today's estimates overflow the day." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:NumberBox
                Width="130"
                LargeChange="1"
                Maximum="24"
                Minimum="0"
                SmallChange="0.5"
                SpinButtonPlacementMode="Inline"
                Value="{Binding FreeHoursPerDay}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Code24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Enable developer features" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Git links on tasks, plus a commit watcher that closes them for you." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding DeveloperFeaturesEnabled}" />
        </ui:CardControl>

        <ui:CardControl
            Margin="0,0,0,10"
            Visibility="{Binding DeveloperFeaturesEnabled, Converter={StaticResource BoolToVisibility}}">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="BranchFork24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Repository to watch" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding GitRepoStatus}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:TextBox
                Width="280"
                FontFamily="Cascadia Mono, Consolas"
                PlaceholderText="C:\src\my-project"
                Text="{Binding GitRepoPath, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Flash24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Quick capture hotkey" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding HotkeyStatus}" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl>
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Database24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Data location" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding DatabaseLocation}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>
    </StackPanel>
</Page>
