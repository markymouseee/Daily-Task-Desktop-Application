<Page
    x:Class="DailyTasks.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings">

    <StackPanel Margin="28,16,28,0">
        <TextBlock
            Margin="0,0,0,18"
            FontFamily="Segoe UI Variable Display"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
            Text="Settings" />

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="DarkTheme24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Dark theme" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Switch between the light and dark appearance." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Flash24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Quick capture hotkey" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding HotkeyStatus}" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl>
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Database24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Data location" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding DatabaseLocation}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>
    </StackPanel>
</Page>
