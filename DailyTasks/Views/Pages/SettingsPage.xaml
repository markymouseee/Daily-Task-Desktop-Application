<Page
    x:Class="DailyTasks.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings">

    <ScrollViewer
        Margin="0,0,-12,0"
        Padding="0,0,12,0"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,16,28,24">
        <TextBlock Style="{StaticResource PageHeading}" Text="Settings" />
        <TextBlock
            Margin="0,3,0,18"
            Style="{StaticResource PageSubheading}"
            Text="Preferences, appearance, and developer options." />

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="BookQuestionMark24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Getting started" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Replay the walkthrough, or send beta feedback." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <StackPanel Orientation="Horizontal">
                <ui:Button
                    Click="OnReplayTour"
                    Content="Show tour"
                    Icon="{ui:SymbolIcon Play24}" />
                <ui:Button
                    Margin="8,0,0,0"
                    Click="OnSendFeedback"
                    Content="Send feedback"
                    Icon="{ui:SymbolIcon Mail24}" />
            </StackPanel>
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Person24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Your name" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Used for the greeting and your sidebar avatar." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:TextBox
                Width="220"
                PlaceholderText="Mark"
                Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="DarkTheme24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Dark theme" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Switch between the light and dark appearance." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Timer24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Focus session length" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Minutes per Pomodoro." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:NumberBox
                Width="130"
                Maximum="180"
                Minimum="1"
                SpinButtonPlacementMode="Inline"
                Value="{Binding PomodoroMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="ClockAlarm24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Daily recap time" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="When the end-of-day summary appears (24h clock)." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:TextBox
                Width="130"
                PlaceholderText="18:00"
                Text="{Binding RecapTimeText, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Hourglass24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Free hours per day" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Default used to warn when today's estimates overflow the day." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:NumberBox
                Width="130"
                LargeChange="1"
                Maximum="24"
                Minimum="0"
                SmallChange="0.5"
                SpinButtonPlacementMode="Inline"
                Value="{Binding FreeHoursPerDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Code24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Enable developer features" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Git links on tasks, plus a commit watcher that closes them for you." />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:ToggleSwitch IsChecked="{Binding DeveloperFeaturesEnabled}" />
        </ui:CardControl>

        <ui:CardControl
            Margin="0,0,0,10"
            Visibility="{Binding DeveloperFeaturesEnabled, Converter={StaticResource BoolToVisibility}}">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="BranchFork24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Repository to watch" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding GitRepoStatus}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>

            <ui:TextBox
                Width="280"
                FontFamily="Cascadia Mono, Consolas"
                PlaceholderText="C:\src\my-project"
                Text="{Binding GitRepoPath, UpdateSourceTrigger=PropertyChanged}" />
        </ui:CardControl>

        <!--  How-to / demo for the git auto-complete feature  -->
        <Border
            Margin="0,0,0,10"
            Padding="18"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="{Binding DeveloperFeaturesEnabled, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="18"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Symbol="BookQuestionMark24" />
                    <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="How git auto-complete works" />
                </StackPanel>

                <TextBlock
                    Margin="0,10,0,0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap">
                    <Run Text="1." FontWeight="SemiBold" /> <Run Text="Set the repository path above to a folder that contains a" /> <Run FontFamily="Cascadia Mono, Consolas" Text=".git" /> <Run Text="folder." /><LineBreak />
                    <Run Text="2." FontWeight="SemiBold" /> <Run Text="Edit a task and put a marker in its" /> <Run FontWeight="SemiBold" Text="Git link" /> <Run Text="field — e.g." /> <Run FontFamily="Cascadia Mono, Consolas" Text="TASK-42" /> <Run Text="or" /> <Run FontFamily="Cascadia Mono, Consolas" Text="closes #42" /> <Run Text="." /><LineBreak />
                    <Run Text="3." FontWeight="SemiBold" /> <Run Text="Commit in that repo with the marker in the message, e.g." /> <Run FontFamily="Cascadia Mono, Consolas" Text="git commit -m &quot;fix login TASK-42&quot;" /> <Run Text="." /><LineBreak />
                    <Run Text="4." FontWeight="SemiBold" /> <Run Text="Within 30 seconds the task is checked off automatically — or press Check now below." />
                </TextBlock>

                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="11.5"
                    FontStyle="Italic"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    TextWrapping="Wrap"
                    Text="Only commits made after the task was created count, so an old commit won't close a brand-new task." />

                <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                    <ui:Button
                        Padding="14,8"
                        Appearance="Primary"
                        Command="{Binding CheckCommitsNowCommand}"
                        Content="Check now"
                        Icon="{ui:SymbolIcon ArrowSync24}" />
                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding GitCheckResult}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ui:CardControl Margin="0,0,0,10">
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Flash24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Quick capture hotkey" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding HotkeyStatus}" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>

        <ui:CardControl>
            <ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon
                        VerticalAlignment="Center"
                        FontSize="20"
                        Symbol="Database24" />
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="Data location" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding DatabaseLocation}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </ui:CardControl.Header>
        </ui:CardControl>
        </StackPanel>
    </ScrollViewer>
</Page>
