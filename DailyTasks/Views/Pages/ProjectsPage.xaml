<Page
    x:Class="DailyTasks.Views.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Projects">

    <Page.Resources>
        <!--  A project summary card for the hub list.  -->
        <DataTemplate DataType="{x:Type vm:ProjectViewModel}">
            <Border
                Margin="0,0,0,12"
                Padding="16,14"
                Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />
                            <Border
                                Margin="10,1,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding MethodologyBadge}" />
                            </Border>
                            <Border
                                Margin="8,1,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                    Text="{Binding CategoryName}" />
                            </Border>
                            <Border
                                Margin="8,1,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="#33EF4444"
                                CornerRadius="8"
                                Visibility="{Binding BlockedCount, Converter={StaticResource PositiveToVisibility}}">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#EF4444"
                                    Text="{Binding BlockedText}" />
                            </Border>
                        </StackPanel>

                        <TextBlock
                            Margin="0,8,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding ProgressText}" />

                        <Border
                            x:Name="CardTrack"
                            Height="8"
                            Margin="0,8,16,0"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            ClipToBounds="True"
                            CornerRadius="4">
                            <Border
                                HorizontalAlignment="Left"
                                Background="{Binding ProgressFraction, Converter={StaticResource ProgressToBrush}}"
                                CornerRadius="4">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource FractionOfWidth}">
                                        <Binding Path="ProgressFraction" />
                                        <Binding ElementName="CardTrack" Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <ui:Button
                            Padding="12,7"
                            Appearance="Primary"
                            Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Content="Open"
                            Icon="{ui:SymbolIcon Open24}" />
                        <ui:Button
                            Margin="6,0,0,0"
                            Padding="8"
                            Appearance="Transparent"
                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            Icon="{ui:SymbolIcon Delete24}"
                            ToolTip="Delete project" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="28,16,28,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource PageHeading}" Text="Projects" />
                <TextBlock
                    Style="{StaticResource PageSubheading}"
                    Text="Plan real work with phases, subtasks and methodology-aware gating." />
            </StackPanel>

            <ui:Button
                Grid.Column="1"
                Padding="14,9"
                VerticalAlignment="Center"
                Appearance="Primary"
                Command="{Binding NewProjectCommand}"
                Content="New"
                Icon="{ui:SymbolIcon Add24}" />
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer
                Margin="0,0,-12,0"
                Padding="0,0,12,0"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Projects}" />
            </ScrollViewer>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <ui:SymbolIcon
                    HorizontalAlignment="Center"
                    FontSize="40"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Symbol="Folder24" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="No projects yet. Hit New to plan one." />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
