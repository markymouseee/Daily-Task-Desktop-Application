<Page
    x:Class="DailyTasks.Views.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Projects">

    <Page.Resources>
        <CollectionViewSource x:Key="GroupedProjects" Source="{Binding Projects}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Group" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!--  A project card — deliberately unlike a task card: no checkbox, no inline subtasks.  -->
        <DataTemplate x:Key="ProjectCard" DataType="{x:Type vm:ProjectCardViewModel}">
            <Border
                x:Name="Root"
                Margin="0,0,0,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Category accent strip  -->
                    <Border
                        Grid.Column="0"
                        Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                        CornerRadius="14,0,0,14" />

                    <!--  Methodology icon tile  -->
                    <Border
                        Grid.Column="1"
                        Width="46"
                        Height="46"
                        Margin="16,16,0,16"
                        VerticalAlignment="Top"
                        Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                        CornerRadius="12">
                        <ui:SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="22"
                            Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                            Symbol="Flowchart24" />
                    </Border>

                    <!--  Title + meta + progress  -->
                    <StackPanel Grid.Column="2" Margin="14,16,12,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="TitleText"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI Variable Display"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />
                            <Border
                                Margin="10,0,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="10.5"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding MethodologyBadge}" />
                            </Border>
                            <Border
                                x:Name="DoneChip"
                                Margin="8,0,0,0"
                                Padding="7,2"
                                VerticalAlignment="Center"
                                Background="#22C55E"
                                CornerRadius="8"
                                Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon FontSize="11" Foreground="White" Symbol="Checkmark24" />
                                    <TextBlock Margin="3,0,0,0" FontSize="10.5" FontWeight="SemiBold" Foreground="White" Text="Done" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Text="{Binding MethodologyBlurb}"
                            TextTrimming="CharacterEllipsis" />

                        <!--  Progress  -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                x:Name="ProgTrack"
                                Height="7"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                ClipToBounds="True"
                                CornerRadius="4">
                                <Border
                                    HorizontalAlignment="Left"
                                    Background="{Binding ProgressFraction, Converter={StaticResource ProgressToBrush}}"
                                    CornerRadius="4">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource FractionOfWidth}">
                                            <Binding Path="ProgressFraction" />
                                            <Binding ElementName="ProgTrack" Path="ActualWidth" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding PercentComplete, StringFormat='{}{0}%'}" />
                        </Grid>

                        <!--  Meta row  -->
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Border
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                    Text="{Binding CategoryName}" />
                            </Border>
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11.5"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding ProgressText}" />
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11.5"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding StructureText}" />
                            <Border
                                Margin="10,0,0,0"
                                Padding="7,2"
                                VerticalAlignment="Center"
                                Background="#33EF4444"
                                CornerRadius="8"
                                Visibility="{Binding HasBlocked, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#EF4444" Text="{Binding BlockedText}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!--  Actions  -->
                    <StackPanel
                        Grid.Column="3"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <ui:Button
                            Padding="14,8"
                            Appearance="Primary"
                            Command="{Binding OpenCommand}"
                            Content="Open"
                            Icon="{ui:SymbolIcon Open24}" />
                        <ui:Button
                            Margin="6,0,0,0"
                            Padding="8"
                            Appearance="Transparent"
                            Command="{Binding ExportCommand}"
                            Icon="{ui:SymbolIcon DocumentTable24}"
                            ToolTip="Export to Excel" />
                        <ui:Button
                            Margin="2,0,0,0"
                            Padding="8"
                            Appearance="Transparent"
                            Command="{Binding ChangeCommand}"
                            Icon="{ui:SymbolIcon Options24}"
                            ToolTip="Change methodology" />
                        <ui:Button
                            Margin="2,0,0,0"
                            Padding="8"
                            Appearance="Transparent"
                            Command="{Binding DeleteCommand}"
                            Icon="{ui:SymbolIcon Delete24}"
                            ToolTip="Delete project" />
                    </StackPanel>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter TargetName="DoneChip" Property="Visibility" Value="Visible" />
                    <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="28,16,28,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource PageHeading}" Text="Projects" />
                <TextBlock Style="{StaticResource PageSubheading}" Text="Methodology-organized work — phases, Gantt, board and Excel export." />
            </StackPanel>
            <ui:Button
                Grid.Column="1"
                Padding="14,9"
                VerticalAlignment="Center"
                Appearance="Primary"
                Command="{Binding NewProjectCommand}"
                Content="New project"
                Icon="{ui:SymbolIcon Add24}" />
        </Grid>

        <Grid Grid.Row="1">
            <ScrollViewer
                Margin="0,0,-12,0"
                Padding="0,0,12,0"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedProjects}}" ItemTemplate="{StaticResource ProjectCard}">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="2,8,0,10"
                                        Style="{StaticResource SectionLabel}"
                                        Text="{Binding Name}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                </ItemsControl>
            </ScrollViewer>

            <!--  Empty state  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <ui:SymbolIcon
                    HorizontalAlignment="Center"
                    FontSize="42"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Symbol="Flowchart24" />
                <TextBlock
                    Margin="0,12,0,4"
                    HorizontalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="No projects yet" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="Create one with a methodology, or organize a task that has subtasks." />
                <ui:Button
                    Margin="0,14,0,0"
                    Padding="14,9"
                    HorizontalAlignment="Center"
                    Appearance="Primary"
                    Command="{Binding NewProjectCommand}"
                    Content="New project"
                    Icon="{ui:SymbolIcon Add24}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
