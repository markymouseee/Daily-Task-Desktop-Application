<ui:FluentWindow
    x:Class="DailyTasks.Views.ResumeNoteWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Leave a trail"
    Width="480"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24,8,24,24">
        <ui:TitleBar Title="Leave a trail" ShowMaximize="False" ShowMinimize="False" />

        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
            <ui:SymbolIcon
                VerticalAlignment="Center"
                FontSize="18"
                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                Symbol="Comment24" />
            <TextBlock
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="Where did you leave off?" />
        </StackPanel>
        <TextBlock
            Margin="26,4,0,0"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="One line for future-you. It shows on the card when you come back."
            TextWrapping="Wrap" />

        <ui:TextBox
            x:Name="NoteBox"
            Margin="0,14,0,0"
            PlaceholderText="was debugging the auth token refresh, check line 84" />

        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Margin="0,0,8,0"
                Padding="14,8"
                Appearance="Secondary"
                Click="OnSkip"
                Content="Skip" />
            <ui:Button
                Padding="14,8"
                Appearance="Primary"
                Click="OnSave"
                Content="Save note" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
