<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views">

    <!--  Shared by the project detail window and the Today project card.  -->
    <views:FractionToStarConverter x:Key="FractionToStar" />
    <views:FractionOfWidthConverter x:Key="FractionOfWidth" />
    <views:ProgressToBrushConverter x:Key="ProgressToBrush" />
    <views:SubtaskStatusToBrushConverter x:Key="SubtaskStatusToBrush" />
    <views:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
    <views:InverseBoolConverter x:Key="InverseBool" />
    <views:ZeroToVisibilityConverter x:Key="ZeroToVisibility" />
    <views:PositiveToVisibilityConverter x:Key="PositiveToVisibility" />

    <!--  A rounded, three-segment progress bar: green/blue done, red blocked, track remainder.
          Apply to a DataContext exposing DoneFraction / BlockedFraction (0–1).  -->
    <DataTemplate x:Key="PhaseProgressBar">
        <Border
            x:Name="BarTrack"
            Height="8"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            ClipToBounds="True"
            CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <Border Background="{Binding DoneFraction, Converter={StaticResource ProgressToBrush}}">
                    <Border.Width>
                        <MultiBinding Converter="{StaticResource FractionOfWidth}">
                            <Binding Path="DoneFraction" />
                            <Binding ElementName="BarTrack" Path="ActualWidth" />
                        </MultiBinding>
                    </Border.Width>
                </Border>
                <Border Background="#EF4444">
                    <Border.Width>
                        <MultiBinding Converter="{StaticResource FractionOfWidth}">
                            <Binding Path="BlockedFraction" />
                            <Binding ElementName="BarTrack" Path="ActualWidth" />
                        </MultiBinding>
                    </Border.Width>
                </Border>
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
