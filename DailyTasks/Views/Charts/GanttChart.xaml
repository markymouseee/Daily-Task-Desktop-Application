<UserControl
    x:Class="DailyTasks.Views.GanttChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Zoom controls  -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <TextBlock
                Margin="0,0,10,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="{Binding ZoomLabel, StringFormat='Zoom · {0}'}" />
            <ui:Button
                Padding="9,4"
                Command="{Binding ZoomOutCommand}"
                Content="−"
                FontSize="15"
                ToolTip="Zoom out" />
            <ui:Button
                Margin="6,0,0,0"
                Padding="9,4"
                Command="{Binding ZoomInCommand}"
                Content="+"
                FontSize="15"
                ToolTip="Zoom in (Ctrl + scroll)" />
        </StackPanel>

        <Border
            Grid.Row="1"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,1">
                    <TextBlock
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource SectionLabel}"
                        Text="TASK" />
                </Border>
                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,1">
                    <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource SectionLabel}"
                        Text="ASSIGNED" />
                </Border>

                <Border
                    Grid.Row="0"
                    Grid.Column="2"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <ScrollViewer
                        x:Name="HeaderScroll"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden">
                        <Grid Width="{Binding TimelineWidth}" Height="30">
                            <ItemsControl ItemsSource="{Binding Columns}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="8" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:GanttColumn}">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Label}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Canvas Visibility="{Binding HasToday, Converter={StaticResource BoolToVisibility}}">
                                <Border
                                    Canvas.Left="{Binding TodayX}"
                                    Canvas.Top="4"
                                    Padding="5,1"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    CornerRadius="6">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="-14" />
                                    </Border.RenderTransform>
                                    <TextBlock
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Today" />
                                </Border>
                            </Canvas>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                    <ScrollViewer
                        x:Name="LabelScroll"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding Rows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttBarRow}">
                                    <Border x:Name="RowBg" Height="{x:Static vm:GanttViewModel.RowPitch}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="132" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                x:Name="NameText"
                                                Grid.Column="0"
                                                Margin="{Binding Indent, Converter={StaticResource IndentToMargin}}"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding Label}"
                                                TextTrimming="CharacterEllipsis" />

                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="12,0,8,0"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Visibility="{Binding HasAssignee, Converter={StaticResource BoolToVisibility}}">
                                                <views:Avatar
                                                    VerticalAlignment="Center"
                                                    ColorHex="{Binding AssigneeColor}"
                                                    DisplayName="{Binding AssigneeName}"
                                                    Size="20" />
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding AssigneeFirstName}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsPhase}" Value="True">
                                            <Setter TargetName="RowBg" Property="Background" Value="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" />
                                            <Setter TargetName="NameText" Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <ScrollViewer
                    x:Name="BodyScroll"
                    Grid.Row="1"
                    Grid.Column="2"
                    HorizontalScrollBarVisibility="Auto"
                    PreviewMouseWheel="OnBodyWheel"
                    ScrollChanged="OnBodyScrollChanged"
                    VerticalScrollBarVisibility="Auto">
                    <!--  Top/Left, or an explicit-Height Grid gets centred in a taller viewport,
                          knocking the bars out of line with the frozen label rows.  -->
                    <Grid
                        Width="{Binding TimelineWidth}"
                        Height="{Binding BodyHeight}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                        <ItemsControl ItemsSource="{Binding Rows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="0" />
                                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttBarRow}">
                                    <Border
                                        Width="{Binding DataContext.TimelineWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Height="{x:Static vm:GanttViewModel.RowPitch}"
                                        Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                                        Opacity="0.6"
                                        Visibility="{Binding IsPhase, Converter={StaticResource BoolToVisibility}}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="0" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttColumn}">
                                    <Border
                                        Width="1"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        Background="{DynamicResource CardStrokeColorDefaultBrush}"
                                        Opacity="0.5" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Connectors}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttConnector}">
                                    <Polyline
                                        Points="{Binding Points}"
                                        Stroke="{DynamicResource TextFillColorTertiaryBrush}"
                                        StrokeThickness="1.5" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Rows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding BarLeft}" />
                                    <Setter Property="Canvas.Top" Value="{Binding BarTop}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:GanttBarRow}">
                                    <Button
                                        Command="{Binding DataContext.ActivateRowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CardButton}"
                                        Visibility="{Binding HasBar, Converter={StaticResource BoolToVisibility}}">
                                        <Grid Width="{Binding BarWidth}" Height="{x:Static vm:GanttViewModel.BarHeight}">
                                            <Border
                                                Background="{Binding Status, Converter={StaticResource SubtaskStatusToBrush}}"
                                                CornerRadius="5"
                                                Opacity="{Binding BarOpacity}" />
                                            <Border
                                                Width="{Binding BlockedWidth}"
                                                HorizontalAlignment="Left"
                                                Background="#EF4444"
                                                CornerRadius="5,0,0,5"
                                                Opacity="0.9"
                                                Visibility="{Binding HasBlocked, Converter={StaticResource BoolToVisibility}}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Canvas Visibility="{Binding HasToday, Converter={StaticResource BoolToVisibility}}">
                            <Border
                                Canvas.Left="{Binding TodayX}"
                                Width="2"
                                Height="{Binding BodyHeight}"
                                Background="{DynamicResource AccentFillColorDefaultBrush}" />
                        </Canvas>

                        <TextBlock
                            Margin="24"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="No dated work yet — add start/due dates to child tasks to see the timeline."
                            Visibility="{Binding HasBars, Converter={StaticResource InverseBoolToVisibility}}" />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!--  Legend  -->
        <StackPanel
            Grid.Row="2"
            Margin="2,12,0,0"
            Orientation="Horizontal">
            <StackPanel Margin="0,0,18,0" Orientation="Horizontal">
                <Border Width="12" Height="12" VerticalAlignment="Center" Background="#22C55E" CornerRadius="3" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Done" />
            </StackPanel>
            <StackPanel Margin="0,0,18,0" Orientation="Horizontal">
                <Border Width="12" Height="12" VerticalAlignment="Center" Background="#3B82F6" CornerRadius="3" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="In Progress" />
            </StackPanel>
            <StackPanel Margin="0,0,18,0" Orientation="Horizontal">
                <Border Width="12" Height="12" VerticalAlignment="Center" Background="#EF4444" CornerRadius="3" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Blocked" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="12" Height="12" VerticalAlignment="Center" Background="#64748B" CornerRadius="3" />
                <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Upcoming" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
