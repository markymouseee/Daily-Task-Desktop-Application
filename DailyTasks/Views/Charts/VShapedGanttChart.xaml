<UserControl
    x:Class="DailyTasks.Views.VShapedGanttChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="2,0,0,10" Orientation="Horizontal">
            <TextBlock
                FontSize="12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Development phases (top) each verify against their paired testing phase (bottom)." />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="4"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                    <!--  Connector lines behind the boxes  -->
                    <ItemsControl ItemsSource="{Binding Connectors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:VConnector}">
                                <Polyline
                                    Points="{Binding Points}"
                                    Stroke="{DynamicResource AccentFillColorDefaultBrush}"
                                    StrokeDashArray="3 2"
                                    StrokeThickness="1.5" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!--  Phase boxes  -->
                    <ItemsControl ItemsSource="{Binding Boxes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:VPhaseBox}">
                                <Border
                                    Width="{Binding Width}"
                                    Height="{Binding Height}"
                                    Background="{Binding Status, Converter={StaticResource SubtaskStatusToBrush}, ConverterParameter=Fill}"
                                    CornerRadius="9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Background="{Binding Status, Converter={StaticResource SubtaskStatusToBrush}}"
                                            CornerRadius="9,0,0,9" />
                                        <StackPanel Grid.Column="1" Margin="10,8" VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding ProgressText}" />
                                            <TextBlock
                                                Margin="0,1,0,0"
                                                FontSize="10.5"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Text="{Binding RangeText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
