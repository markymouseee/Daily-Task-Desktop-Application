<ui:FluentWindow
    x:Class="DailyTasks.Views.CommitsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Commits"
    Width="620"
    Height="640"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="24,8,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="{Binding ProjectTitle, StringFormat='{}{0} — commits'}"
            ShowMaximize="False"
            ShowMinimize="False" />

        <!--  Repo path  -->
        <Border
            Grid.Row="1"
            Margin="0,8,0,12"
            Padding="16,14"
            Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource CardTitle}" Text="Repository this project watches" />
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontFamily="Cascadia Mono, Consolas"
                        PlaceholderText="C:\src\my-project"
                        Text="{Binding RepoPath, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="14,8"
                        VerticalAlignment="Center"
                        Appearance="Primary"
                        Command="{Binding SaveCommand}"
                        Content="Save" />
                </Grid>
                <TextBlock
                    Margin="0,8,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding StatusText}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!--  Header row  -->
        <Grid Grid.Row="2" Margin="4,0,4,6">
            <TextBlock
                HorizontalAlignment="Left"
                Style="{StaticResource SectionLabel}"
                Text="Recent commits" />
            <ui:Button
                HorizontalAlignment="Right"
                Padding="10,5"
                Appearance="Secondary"
                Command="{Binding RefreshCommand}"
                Content="Refresh"
                Icon="{ui:SymbolIcon ArrowSync24}" />
        </Grid>

        <!--  Commit list  -->
        <Grid Grid.Row="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Commits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="12,10"
                                Style="{StaticResource Card}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border
                                            Padding="6,1"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="5">
                                            <TextBlock
                                                FontFamily="Cascadia Mono, Consolas"
                                                FontSize="11"
                                                Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                Text="{Binding ShortHash}" />
                                        </Border>
                                        <TextBlock
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Text="{Binding When, StringFormat='ddd d MMM, HH:mm'}" />
                                    </StackPanel>
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Text="{Binding Subject}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <ui:SymbolIcon
                    HorizontalAlignment="Center"
                    FontSize="36"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Symbol="BranchFork24" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="No commits to show. Set a valid repository above." />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
