<ui:FluentWindow
    x:Class="DailyTasks.Views.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Welcome to DailyTasks"
    Width="560"
    Height="600"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    Icon="pack://application:,,,/Assets/appicon.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Header>
                <StackPanel Margin="14,0,0,0" Orientation="Horizontal">
                    <Image Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality" Source="pack://application:,,,/Assets/appicon.ico" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="DailyTasks" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!--  Step content  -->
        <StackPanel
            Grid.Row="1"
            Margin="40,10,40,0"
            VerticalAlignment="Center">
            <Border
                Width="96"
                Height="96"
                HorizontalAlignment="Center"
                CornerRadius="26">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#6366F1" />
                        <GradientStop Offset="1" Color="#3B82F6" />
                    </LinearGradientBrush>
                </Border.Background>
                <ui:SymbolIcon
                    x:Name="StepIcon"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="44"
                    Foreground="White"
                    Symbol="Rocket24" />
            </Border>

            <TextBlock
                x:Name="StepTitle"
                Margin="0,24,0,0"
                HorizontalAlignment="Center"
                FontFamily="Segoe UI Variable Display"
                FontSize="24"
                FontWeight="Bold"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Text="Welcome" />

            <TextBlock
                x:Name="StepBody"
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                LineHeight="22"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  Progress dots  -->
        <ItemsControl
            x:Name="Dots"
            Grid.Row="2"
            Margin="0,24,0,0"
            HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!--  Buttons  -->
        <Grid Grid.Row="3" Margin="24,20,24,24">
            <ui:Button
                x:Name="SkipButton"
                HorizontalAlignment="Left"
                Padding="12,8"
                Appearance="Transparent"
                Click="OnSkip"
                Content="Skip tour" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <ui:Button
                    x:Name="BackButton"
                    Margin="0,0,8,0"
                    Padding="16,8"
                    Appearance="Secondary"
                    Click="OnBack"
                    Content="Back" />
                <ui:Button
                    x:Name="NextButton"
                    Padding="18,8"
                    Appearance="Primary"
                    Click="OnNext"
                    Content="Next" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
