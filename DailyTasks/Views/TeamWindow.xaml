<ui:FluentWindow
    x:Class="DailyTasks.Views.TeamWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:DailyTasks.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Team"
    Width="520"
    Height="640"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="24,8,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Team"
            ShowMaximize="False"
            ShowMinimize="False" />

        <!--  Add / edit form  -->
        <Border
            Grid.Row="1"
            Margin="0,8,0,16"
            Padding="16,14"
            Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Style="{StaticResource CardTitle}" Text="{Binding FormTitle}" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Name" />
                        <ui:TextBox PlaceholderText="Alex Rivera" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Role" />
                        <ui:TextBox PlaceholderText="Frontend Dev" Text="{Binding EditRole, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <TextBlock
                    Margin="0,14,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Scrum role (optional)" />
                <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{Binding ScrumRoleIndex}">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Scrum Master" />
                    <ComboBoxItem Content="Product Owner" />
                    <ComboBoxItem Content="Dev Team" />
                </ComboBox>

                <TextBlock
                    Margin="0,14,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Avatar colour" />
                <ItemsControl ItemsSource="{Binding Swatches}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ColorSwatch}">
                            <Button
                                Margin="0,0,8,0"
                                Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource CardButton}">
                                <Border
                                    x:Name="Ring"
                                    Width="30"
                                    Height="30"
                                    Padding="3"
                                    BorderBrush="Transparent"
                                    BorderThickness="2"
                                    CornerRadius="999">
                                    <Border Background="{Binding Hex, Converter={StaticResource HexToBrush}}" CornerRadius="999" />
                                </Border>
                            </Button>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Ring" Property="BorderBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Padding="14,7"
                        Appearance="Secondary"
                        Command="{Binding CancelEditCommand}"
                        Content="Cancel"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                    <ui:Button
                        Padding="14,7"
                        Appearance="Primary"
                        Command="{Binding SaveCommand}"
                        Content="{Binding SaveLabel}"
                        Icon="{ui:SymbolIcon Add24}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock
            Grid.Row="2"
            Margin="2,0,0,10"
            Style="{StaticResource SectionLabel}"
            Text="MEMBERS" />

        <Grid Grid.Row="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Members}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TeamMember}">
                            <Border
                                Margin="0,0,0,8"
                                Padding="12,10"
                                Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <views:Avatar
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        ColorHex="{Binding InitialsColorHex}"
                                        DisplayName="{Binding Name}"
                                        Size="34" />

                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Text="{Binding Name}" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding Role}"
                                                Visibility="{Binding Role, Converter={StaticResource EmptyToVisibility}}" />
                                            <Border
                                                Margin="6,0,0,0"
                                                Padding="6,1"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="7"
                                                Visibility="{Binding ScrumRoleText, Converter={StaticResource EmptyToVisibility}}">
                                                <TextBlock
                                                    FontSize="10.5"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="{Binding ScrumRoleText}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <ui:Button
                                            Padding="7"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Edit24}"
                                            ToolTip="Edit" />
                                        <ui:Button
                                            Padding="7"
                                            Appearance="Transparent"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Icon="{ui:SymbolIcon Delete24}"
                                            ToolTip="Remove" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding Members.Count, Converter={StaticResource ZeroToVisibility}}">
                <ui:SymbolIcon
                    HorizontalAlignment="Center"
                    FontSize="34"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Symbol="People24" />
                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="No team members yet. Add one above." />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
