<ui:FluentWindow
    x:Class="DailyTasks.Views.NewProjectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="New"
    Width="520"
    MaxHeight="820"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Create something new"
            ShowMaximize="False"
            ShowMinimize="False" />

        <!--  Simple vs Project toggle  -->
        <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal">
            <RadioButton
                x:Name="SimpleToggle"
                Margin="0,0,20,0"
                Checked="OnTypeChanged"
                Content="Simple task"
                GroupName="Type"
                IsChecked="True" />
            <RadioButton
                x:Name="ProjectToggle"
                Checked="OnTypeChanged"
                Content="Project"
                GroupName="Type" />
        </StackPanel>

        <ScrollViewer
            Grid.Row="2"
            Margin="0,4,-12,0"
            Padding="0,0,12,0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock
                    Margin="0,12,0,6"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="Title" />
                <ui:TextBox x:Name="TitleBox" PlaceholderText="Ship the billing rewrite" />

                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Category" />
                        <ComboBox
                            x:Name="CategoryBox"
                            HorizontalAlignment="Stretch"
                            DisplayMemberPath="Name" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Priority" />
                        <ComboBox x:Name="PriorityBox" Width="110" SelectedIndex="1">
                            <ComboBoxItem Content="High" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="Low" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Due date" />
                        <DatePicker x:Name="DueBox" Width="140" />
                    </StackPanel>
                </Grid>

                <!--  Methodology picker — only for projects  -->
                <StackPanel x:Name="MethodologySection" Visibility="Collapsed">
                    <TextBlock
                        Margin="0,20,0,8"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="How do you want to run it?" />

                    <RadioButton
                        x:Name="WaterfallRadio"
                        Margin="0,0,0,6"
                        Checked="OnMethodologyChanged"
                        GroupName="Methodology"
                        IsChecked="True">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Waterfall" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="Requirements → Design → Implementation → Testing → Deployment → Maintenance. Each phase is locked until the previous one is 100% done."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="AgileRadio"
                        Margin="0,0,0,6"
                        Checked="OnMethodologyChanged"
                        GroupName="Methodology">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Agile" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="Backlog, Sprint, Review, Done. Phases group work without hard gating — good for evolving scope."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="IterativeRadio"
                        Margin="0,0,0,6"
                        Checked="OnMethodologyChanged"
                        GroupName="Methodology">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Iterative" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="Repeat Plan → Build → Test → Review across a set number of iterations, each with its own progress."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="KanbanRadio"
                        Margin="0,0,0,6"
                        Checked="OnMethodologyChanged"
                        GroupName="Methodology">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Kanban" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="A simple board — To Do, In Progress, Review, Done. Move cards freely, no locking."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton
                        x:Name="CustomRadio"
                        Margin="0,0,0,6"
                        Checked="OnMethodologyChanged"
                        GroupName="Methodology">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Custom" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                Text="Define your own phase names, in the order you want them."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </RadioButton>

                    <!--  Iterative: how many iterations  -->
                    <StackPanel x:Name="IterationRow" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Number of iterations" />
                        <ui:NumberBox
                            x:Name="IterationCountBox"
                            Width="140"
                            HorizontalAlignment="Left"
                            Maximum="20"
                            Minimum="1"
                            SpinButtonPlacementMode="Inline"
                            Value="3" />
                    </StackPanel>

                    <!--  Custom: phase names  -->
                    <StackPanel x:Name="CustomPhasesRow" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Phase names — one per line, in order" />
                        <ui:TextBox
                            x:Name="CustomPhasesBox"
                            AcceptsReturn="True"
                            MinHeight="90"
                            TextWrapping="Wrap"
                            PlaceholderText="Discovery&#x0a;Prototype&#x0a;Build&#x0a;Launch" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            Grid.Row="3"
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Margin="0,0,8,0"
                Padding="14,8"
                Appearance="Secondary"
                Click="OnCancel"
                Content="Cancel" />
            <ui:Button
                x:Name="CreateButton"
                Padding="14,8"
                Appearance="Primary"
                Click="OnCreate"
                Content="Create task"
                Icon="{ui:SymbolIcon Add24}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
