<ui:FluentWindow
    x:Class="DailyTasks.Views.ProjectDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:DailyTasks.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:DailyTasks.Views"
    xmlns:vm="clr-namespace:DailyTasks.ViewModels"
    Title="Project"
    Width="960"
    Height="720"
    MinWidth="720"
    MinHeight="520"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    FontFamily="Segoe UI Variable Text"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!--  A subtask card, used in phase lists and Kanban columns within this window.  -->
        <DataTemplate DataType="{x:Type vm:SubtaskViewModel}">
            <Border
                x:Name="SubCard"
                Margin="0,0,0,8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Background="{Binding Status, Converter={StaticResource SubtaskStatusToBrush}}"
                        CornerRadius="7,0,0,7" />

                    <StackPanel Grid.Column="1" Margin="10,8,8,8">
                        <TextBlock
                            x:Name="SubTitle"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis" />

                        <TextBlock
                            Margin="0,2,0,0"
                            FontSize="11"
                            FontStyle="Italic"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Text="{Binding WhyReason}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="{Binding WhyReason, Converter={StaticResource EmptyToVisibility}}" />

                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <!--  Status pill  -->
                            <Border
                                Padding="7,2"
                                VerticalAlignment="Center"
                                Background="{Binding Status, Converter={StaticResource SubtaskStatusToBrush}, ConverterParameter=Fill}"
                                CornerRadius="7">
                                <TextBlock
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding Status, Converter={StaticResource SubtaskStatusToBrush}}"
                                    Text="{Binding StatusLabel}" />
                            </Border>

                            <!--  Blocked badge with the reason on hover  -->
                            <Border
                                Margin="6,0,0,0"
                                Padding="7,2"
                                VerticalAlignment="Center"
                                Background="#33EF4444"
                                CornerRadius="7"
                                ToolTip="{Binding BlockedReason}"
                                Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#EF4444"
                                        Symbol="Warning24" />
                                    <TextBlock
                                        Margin="4,0,0,0"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#EF4444"
                                        Text="Blocked" />
                                </StackPanel>
                            </Border>

                            <!--  Assignee badge  -->
                            <StackPanel
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Visibility="{Binding HasAssignee, Converter={StaticResource BoolToVisibility}}">
                                <views:Avatar
                                    VerticalAlignment="Center"
                                    ColorHex="{Binding AssigneeColor}"
                                    DisplayName="{Binding AssigneeName}"
                                    Size="18" />
                                <TextBlock
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="{Binding AssigneeFirstName}" />
                            </StackPanel>

                            <!--  Priority  -->
                            <ui:SymbolIcon
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{Binding Priority, Converter={StaticResource PriorityToBrush}}"
                                Symbol="Flag24" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding Priority}" />

                            <!--  Hours  -->
                            <TextBlock
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding HoursText}"
                                Visibility="{Binding HoursText, Converter={StaticResource EmptyToVisibility}}" />

                            <!--  Git pattern  -->
                            <ui:SymbolIcon
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Symbol="BranchFork24"
                                Visibility="{Binding GitLinkPattern, Converter={StaticResource EmptyToVisibility}}" />
                            <TextBlock
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="Cascadia Mono, Consolas"
                                FontSize="10"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="{Binding GitLinkPattern}"
                                Visibility="{Binding GitLinkPattern, Converter={StaticResource EmptyToVisibility}}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="2"
                        Margin="0,4,4,0"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <ui:Button
                            Padding="6"
                            Appearance="Transparent"
                            Command="{Binding DataContext.EditSubtaskCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                            CommandParameter="{Binding}"
                            Icon="{ui:SymbolIcon Edit24}"
                            ToolTip="Edit subtask" />
                        <ui:Button
                            Padding="6"
                            Appearance="Transparent"
                            Command="{Binding DataContext.DeleteSubtaskCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                            CommandParameter="{Binding}"
                            Icon="{ui:SymbolIcon Delete24}"
                            ToolTip="Delete subtask" />
                    </StackPanel>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsDone}" Value="True">
                    <Setter TargetName="SubTitle" Property="TextDecorations" Value="Strikethrough" />
                    <Setter TargetName="SubTitle" Property="Opacity" Value="0.55" />
                </DataTrigger>
                <!--  Highlighted after jumping from the Gantt view  -->
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter TargetName="SubCard" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                    <Setter TargetName="SubCard" Property="BorderThickness" Value="2" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid Margin="24,8,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="{Binding Title}" />

            <!--  Header: title, methodology, overall progress, export  -->
            <Border
                Grid.Row="1"
                Margin="0,8,0,16"
                Padding="18,16"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontFamily="Segoe UI Variable Display"
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                Text="{Binding Title}"
                                TextTrimming="CharacterEllipsis" />

                            <!--  Methodology badge  -->
                            <Border
                                Margin="12,2,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding MethodologyBadge}" />
                            </Border>

                            <Border
                                Margin="8,2,0,0"
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=Fill}"
                                CornerRadius="8">
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"
                                    Text="{Binding CategoryName}" />
                            </Border>
                        </StackPanel>

                        <TextBlock
                            Margin="0,10,0,0"
                            FontSize="13"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding OverallText}" />

                        <!--  Overall progress bar  -->
                        <Border
                            x:Name="OverallTrack"
                            Height="10"
                            Margin="0,8,0,0"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            ClipToBounds="True"
                            CornerRadius="5">
                            <Border
                                HorizontalAlignment="Left"
                                Background="{Binding OverallFraction, Converter={StaticResource ProgressToBrush}}"
                                CornerRadius="5">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource FractionOfWidth}">
                                        <Binding Path="OverallFraction" />
                                        <Binding ElementName="OverallTrack" Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontFamily="Segoe UI Variable Display"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            Text="{Binding OverallPercent, StringFormat={}{0}%}" />

                        <Border
                            Margin="0,4,0,0"
                            Padding="8,2"
                            HorizontalAlignment="Right"
                            Background="#33EF4444"
                            CornerRadius="7"
                            Visibility="{Binding BlockedCount, Converter={StaticResource PositiveToVisibility}}">
                            <TextBlock
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="#EF4444"
                                Text="{Binding BlockedCount, StringFormat={}{0} blocked}" />
                        </Border>

                        <ui:Button
                            Margin="0,12,0,0"
                            HorizontalAlignment="Right"
                            Appearance="Secondary"
                            Command="{Binding ExportCommand}"
                            Content="Export SDLC to Excel"
                            Icon="{ui:SymbolIcon DocumentTable24}"
                            IsEnabled="{Binding IsExporting, Converter={StaticResource InverseBool}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  List / Gantt view toggle (phased projects only)  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,0,0,14"
                Orientation="Horizontal"
                Visibility="{Binding GanttAvailable, Converter={StaticResource BoolToVisibility}}">
                <RadioButton
                    x:Name="ListToggle"
                    MinWidth="88"
                    Content="List"
                    GroupName="DetailView"
                    IsChecked="{Binding IsGanttView, Converter={StaticResource InverseBool}, Mode=TwoWay}"
                    Style="{StaticResource ViewToggle}" />
                <RadioButton
                    MinWidth="88"
                    Content="Gantt"
                    GroupName="DetailView"
                    IsChecked="{Binding IsGanttView, Mode=TwoWay}"
                    Style="{StaticResource ViewToggle}" />
            </StackPanel>

            <!--  Phased detail (Waterfall / Agile / Iterative / Custom)  -->
            <ScrollViewer
                Grid.Row="3"
                Margin="0,0,-12,0"
                Padding="0,0,12,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding ShowPhasedList, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Phases}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PhaseRowViewModel}">
                            <Border
                                x:Name="PhaseCard"
                                Margin="0,0,0,14"
                                Padding="16,14"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:SymbolIcon
                                                x:Name="LockIcon"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Symbol="LockClosed24"
                                                Visibility="Collapsed" />
                                            <TextBlock
                                                Margin="0,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding DisplayName}" />
                                            <TextBlock
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                Text="{Binding ProgressText}" />
                                        </StackPanel>

                                        <ui:Button
                                            x:Name="AddButton"
                                            Grid.Column="1"
                                            Padding="10,5"
                                            Appearance="Secondary"
                                            Command="{Binding DataContext.AddToPhaseCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="Add subtask"
                                            FontSize="12"
                                            Icon="{ui:SymbolIcon Add24}" />
                                    </Grid>

                                    <ContentControl
                                        Margin="0,10,0,0"
                                        HorizontalContentAlignment="Stretch"
                                        Content="{Binding}"
                                        ContentTemplate="{StaticResource PhaseProgressBar}" />

                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Subtasks}" />

                                    <TextBlock
                                        Margin="2,4,0,2"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                        Text="No subtasks in this phase yet."
                                        Visibility="{Binding Subtasks.Count, Converter={StaticResource ZeroToVisibility}}" />
                                </StackPanel>
                            </Border>

                            <DataTemplate.Triggers>
                                <!--  Waterfall: a gated phase is dimmed and non-interactive  -->
                                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                    <Setter TargetName="PhaseCard" Property="Opacity" Value="0.45" />
                                    <Setter TargetName="PhaseCard" Property="IsEnabled" Value="False" />
                                    <Setter TargetName="LockIcon" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!--  Gantt timeline (phased projects), an alternate view of the same data  -->
            <views:GanttChart
                Grid.Row="3"
                DataContext="{Binding Gantt}"
                Visibility="{Binding DataContext.IsGanttView, RelativeSource={RelativeSource AncestorType={x:Type ui:FluentWindow}}, Converter={StaticResource BoolToVisibility}}" />

            <!--  Kanban board  -->
            <Grid
                Grid.Row="3"
                Visibility="{Binding IsKanban, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  To Do  -->
                <Border
                    Grid.Column="0"
                    Margin="0,0,6,0"
                    Padding="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="To Do" />
                            <ui:Button
                                Grid.Column="1"
                                Padding="6"
                                Appearance="Transparent"
                                Command="{Binding AddKanbanCommand}"
                                Icon="{ui:SymbolIcon Add24}"
                                ToolTip="Add subtask" />
                        </Grid>
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                x:Name="TodoColumnHost"
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding TodoColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:SubtaskStatus.Todo}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!--  In Progress  -->
                <Border
                    Grid.Column="1"
                    Margin="6,0,6,0"
                    Padding="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <DockPanel>
                        <TextBlock
                            DockPanel.Dock="Top"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="In Progress" />
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding InProgressColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:SubtaskStatus.InProgress}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!--  Review  -->
                <Border
                    Grid.Column="2"
                    Margin="6,0,6,0"
                    Padding="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <DockPanel>
                        <TextBlock
                            DockPanel.Dock="Top"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Review" />
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding ReviewColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:SubtaskStatus.Review}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!--  Done  -->
                <Border
                    Grid.Column="3"
                    Margin="6,0,0,0"
                    Padding="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <DockPanel>
                        <TextBlock
                            DockPanel.Dock="Top"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="Done" />
                        <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl
                                AllowDrop="True"
                                Drop="OnColumnDrop"
                                ItemsSource="{Binding DoneColumn}"
                                PreviewMouseLeftButtonDown="OnCardPreviewDown"
                                PreviewMouseMove="OnCardPreviewMove"
                                Tag="{x:Static models:SubtaskStatus.Done}" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!--  Export loading veil  -->
        <Border
            Background="#99000000"
            Visibility="{Binding IsExporting, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    Foreground="White"
                    Text="Building your Excel workbook…" />
            </StackPanel>
        </Border>

        <!--  Mark project complete prompt  -->
        <Border Background="#B2000000" Visibility="{Binding ShowCompletePrompt, Converter={StaticResource BoolToVisibility}}">
            <Border
                MaxWidth="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel>
                    <TextBlock
                        FontFamily="Segoe UI Variable Display"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="Every subtask is done." />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Mark the whole project complete?"
                        TextWrapping="Wrap" />
                    <StackPanel
                        Margin="0,18,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <ui:Button
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Appearance="Secondary"
                            Command="{Binding DismissCompletePromptCommand}"
                            Content="Not yet" />
                        <ui:Button
                            Padding="14,8"
                            Appearance="Primary"
                            Command="{Binding MarkProjectCompleteCommand}"
                            Content="Mark complete"
                            Icon="{ui:SymbolIcon CheckmarkCircle24}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</ui:FluentWindow>
